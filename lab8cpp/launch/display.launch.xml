<!-- ===== LAUNCH-ФАЙЛ ДЛЯ ВИЗУАЛИЗАЦИИ РОБОТА В ROS 2 ===== -->
<launch>
    <!-- ===== ОБЪЯВЛЕНИЕ ПЕРЕМЕННЫХ ДЛЯ ПУТЕЙ ===== -->
    <let name="urdf_path" value="$(find-pkg-share lab8cpp)/resource/robot.urdf.xacro" />
    <let name="rviz_config_path" value="$(find-pkg-share lab8cpp)/rviz/config.rviz" />
    <let name="gazebo_config_path" value="$(find-pkg-share lab8cpp)/config/gazebo_bridge.yaml" />
    
    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="use_tf_static" value="false"/>
        <param name="publish_frequency" value="25.0"/>
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>
    <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" />
    <node pkg="rviz2" exec="rviz2" args="-d $(var rviz_config_path)" />
    <!---->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="empty.sdf -r" />
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description -z 0.1 -name robot" />

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

</launch>